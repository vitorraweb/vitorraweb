APP_NAME="Vitorra Holdings"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database ───────────────────────────────────────────────────────────────
# SQLite (dev default — zero setup)
DB_CONNECTION=sqlite
# Switch to PostgreSQL for production:
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=vitorra
# DB_USERNAME=vitorra
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# ── Mail ───────────────────────────────────────────────────────────────────
# Development: log driver writes to storage/logs (no real email sent)
MAIL_MAILER=log
# Production: switch to smtp or postmark
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.postmarkapp.com
# MAIL_PORT=587
# MAIL_USERNAME=your-postmark-token
# MAIL_PASSWORD=your-postmark-token
# MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@vitorra.org"
MAIL_FROM_NAME="Vitorra Holdings"
# Inbox that receives enquiry + contact form submissions
MAIL_TEAM_ADDRESS="support@vitorra.org"

# ── Frontend ───────────────────────────────────────────────────────────────
# CORS: allowed origin for the Next.js frontend
FRONTEND_URL=http://localhost:3000
# Production: FRONTEND_URL=https://vitorra.org

# ── Payments (wired in Phase 2) ────────────────────────────────────────────
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# ── Exchange rate API (wired in Phase 2) ──────────────────────────────────
EXCHANGE_RATE_API_KEY=

# ── Media storage (Cloudinary or S3 — wired in Phase 2) ───────────────────
# CLOUDINARY_URL=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=
# AWS_BUCKET=
