rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Users ──────────────────────────────────────────────────────────────
    // Users can read/write their own profile
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      // User's own orders subcollection (read-only for the user, written by Cloud Functions)
      match /orders/{orderId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false; // Only Cloud Functions (admin SDK) can write
      }
    }

    // ─── Orders (Central Collection) ────────────────────────────────────────
    // Only Cloud Functions can create orders (enforced by admin SDK bypass)
    // Users can read their own orders
    // Admins can read/update all orders
    match /orders/{orderId} {
      allow read: if request.auth != null && (
        resource.data.customerId == request.auth.uid ||
        isAdmin()
      );
      allow create: if false; // Only via Cloud Functions
      allow update: if request.auth != null && isAdmin();
      allow delete: if false;
    }

    // ─── Products ───────────────────────────────────────────────────────────
    // Everyone can read products
    // Only admins can update product details
    // Stock updates go through Cloud Functions (admin SDK)
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }

    // ─── Categories ─────────────────────────────────────────────────────────
    match /categories/{catId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }

    // ─── CMS Content (Blogs, Jobs) ──────────────────────────────────────────
    match /blogs/{blogId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }
    match /jobs/{jobId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }

    // ─── Settings ───────────────────────────────────────────────────────────
    match /settings/{settingId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }

    // ─── Helper Function ────────────────────────────────────────────────────
    function isAdmin() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'Super Admin', 'Ops Manager'];
    }
  }
}
